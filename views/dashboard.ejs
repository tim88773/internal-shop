<% var s = stats; %>
<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">儀表板</h1>
    <span class="text-muted"><%= currentUser.display_name %>，歡迎使用</span>
  </div>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="value"><%= s.productCount.cnt %></div>
      <div class="label">上架商品數</div>
    </div>
    <div class="stat-card">
      <div class="value"><%= s.activeOrders.cnt %></div>
      <div class="label">進行中訂單</div>
    </div>
    <div class="stat-card">
      <div class="value"><%= s.lowStockCount.cnt %></div>
      <div class="label">低庫存商品 (&le;3)</div>
    </div>
    <div class="stat-card">
      <div class="value"><%= s.totalEmployees.cnt %></div>
      <div class="label">員工人數</div>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2>最近訂單</h2>
      <div class="btn-group">
        <a href="/products" class="btn btn-primary btn-sm">瀏覽商品</a>
        <a href="/orders" class="btn btn-outline btn-sm">查看所有訂單</a>
      </div>
    </div>

    <% if (recentOrders.length === 0) { %>
      <div class="empty-state">
        <div class="icon">&#x1F6D2;</div>
        <p>目前還沒有任何訂單，去看看有什麼好東西吧！</p>
        <a href="/products" class="btn btn-primary mt-4">前往商品區</a>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>訂單編號</th>
              <th>下單員工</th>
              <th>品項數</th>
              <th>狀態</th>
              <th>下單時間</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% recentOrders.forEach(function(o) { %>
            <tr>
              <td>#<%= o.id %></td>
              <td><%= o.display_name %></td>
              <td><%= o.items_count %></td>
              <td><span class="status status-<%= o.status %>"><%= o.status === 'pending' ? '待處理' : o.status === 'completed' ? '已完成' : '已取消' %></span></td>
              <td class="text-muted"><%= new Date(o.created_at).toLocaleString('zh-TW') %></td>
              <td><a href="/orders/<%= o.id %>" class="btn btn-outline btn-sm">查看</a></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
