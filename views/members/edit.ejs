<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x270F; 編輯會員</h1>
    <a href="/members" class="btn btn-outline">返回列表</a>
  </div>

  <div class="card" style="max-width:500px;margin:0 auto;">
    <form action="/members/<%= member.id %>/edit" method="POST">
      <div class="form-group">
        <label for="display_name">顯示名稱</label>
        <input type="text" id="display_name" name="display_name" value="<%= member.display_name %>" required>
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" value="<%= member.email || '' %>">
      </div>
      <div class="form-group">
        <label for="store">所屬門市</label>
        <input type="text" id="store" name="store" value="<%= member.store || '' %>" placeholder="如：台北門市">
      </div>

      <!-- Points info display -->
      <hr style="border:none;border-top:1px solid var(--border);margin:20px 0;">
      <div style="font-size:14px;">
        <div class="flex-between" style="margin-bottom:6px;">
          <span class="text-muted">目前積點</span>
          <span style="font-weight:600;color:var(--warning);"><%= Number(member.points || 0).toLocaleString() %> 點</span>
        </div>
        <div class="flex-between" style="margin-bottom:6px;">
          <span class="text-muted">累積獲得積點</span>
          <span><%= Number(member.points_total_earned || 0).toLocaleString() %> 點</span>
        </div>
        <div class="flex-between">
          <span class="text-muted">累積使用積點</span>
          <span><%= Number(member.points_total_spent || 0).toLocaleString() %> 點</span>
        </div>
      </div>
      <div style="text-align:center;margin-top:12px;">
        <a href="/members/<%= member.id %>/points" class="btn btn-outline btn-sm">點數異動</a>
        <a href="/members/<%= member.id %>/point-history" class="btn btn-outline btn-sm">查看歷程</a>
      </div>

      <hr style="border:none;border-top:1px solid var(--border);margin:20px 0;">

      <p class="text-muted" style="font-size:13px;margin-bottom:12px;">如需更改密碼請填寫以下欄位</p>
      <div class="form-row">
        <div class="form-group">
          <label for="password">新密碼</label>
          <input type="password" id="password" name="password" placeholder="留空則不修改" minlength="4">
        </div>
        <div class="form-group">
          <label for="confirm_password">確認新密碼</label>
          <input type="password" id="confirm_password" name="confirm_password" placeholder="再次輸入新密碼">
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-block">&#x1F504; 更新資料</button>
    </form>
  </div>
</div>
