<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F4C4; 订单 #<%= order.id %></h1>
    <div class="btn-group">
      <a href="/orders" class="btn btn-outline">回订单列表</a>
      <% if (order.status === 'pending') { %>
        <form action="/orders/<%= order.id %>/cancel" method="POST" onsubmit="return confirm('确定要取消此订单？库存将自动恢复。')">
          <button type="submit" class="btn btn-danger">取消订单</button>
        </form>
      <% } %>
      <% if (nextStatus) { %>
        <form action="/orders/<%= order.id %>/advance" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-success">设为「<%= statusLabel(nextStatus) %>」</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="flex-between mb-2">
      <div>
        <div class="text-muted" style="font-size:13px;">下单员工</div>
        <div style="font-weight:600;"><%= order.display_name %></div>
        <% if (order.email) { %><div class="text-muted" style="font-size:12px;"><%= order.email %></div><% } %>
      </div>
      <div style="text-align:right;">
        <div class="text-muted" style="font-size:13px;">状态</div>
        <span class="status status-<%= order.status %>" style="font-size:14px;padding:4px 14px;">
          <%= statusLabel(order.status) %>
        </span>
      </div>
    </div>
    <div class="text-muted" style="font-size:13px;margin-top:8px;">
      下单时间：<%= new Date(order.created_at).toLocaleString('zh-TW') %>
    </div>
    <% if (order.notes) { %>
      <div style="margin-top:8px;padding:10px;background:#f8fafc;border-radius:6px;font-size:13px;">
        <strong>备注：</strong><%= order.notes %>
      </div>
    <% } %>
  </div>

  <div class="card">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:12px;">订单明细</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>商品</th>
            <th>瑕疵说明</th>
            <th>单价</th>
            <th>数量</th>
            <th>小计</th>
          </tr>
        </thead>
        <tbody>
          <% var sum = 0; %>
          <% items.forEach(function(item) { %>
          <% var subtotal = item.unit_price * item.quantity; sum += subtotal; %>
          <tr>
            <td style="display:flex;align-items:center;gap:8px;"><% if (item.image_url) { %><img src="<%= item.image_url %>" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:4px;border:1px solid var(--border);"><% } %><strong><%= item.name %></strong></td>
            <td class="text-muted"><%= item.defect_reason || '-' %></td>
            <td>$<%= Number(item.unit_price).toLocaleString() %></td>
            <td><%= item.quantity %></td>
            <td style="font-weight:600;">$<%= Number(subtotal).toLocaleString() %></td>
          </tr>
          <% }); %>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3"></td>
            <td style="font-weight:600;font-size:16px;">总计</td>
            <td style="font-weight:700;font-size:18px;color:var(--danger);">$<%= Number(sum).toLocaleString() %></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>
</div>
