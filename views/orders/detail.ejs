<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F4C4; 訂單 #<%= order.id %></h1>
    <div class="btn-group">
      <a href="/orders" class="btn btn-outline">回訂單列表</a>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <% if (nextStatus) { %>
          <form action="/orders/<%= order.id %>/advance" method="POST" style="display:inline;">
            <button type="submit" class="btn btn-success">推進至<%= statusLabel(nextStatus) %></button>
          </form>
        <% } %>
        <% if (order.status !== 'delivered' && order.status !== 'cancelled') { %>
          <form action="/orders/<%= order.id %>/cancel" method="POST" onsubmit="return confirm('確定要取消此訂單嗎？取消後庫存和積點將自動回補')">
            <button type="submit" class="btn btn-danger">取消訂單</button>
          </form>
        <% } %>
      <% } else { %>
        <% if (order.status === 'pending') { %>
          <form action="/orders/<%= order.id %>/cancel" method="POST" onsubmit="return confirm('確定要取消訂單嗎？')">
            <button type="submit" class="btn btn-danger">取消訂單</button>
          </form>
        <% } %>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="flex-between mb-2">
      <div>
        <div class="text-muted" style="font-size:13px;">下單人員</div>
        <div style="font-weight:600;"><%= order.display_name %></div>
        <% if (order.email) { %><div class="text-muted" style="font-size:12px;"><%= order.email %></div><% } %>
        <% if (order.store) { %><div class="text-muted" style="font-size:12px;">所屬門市：<%= order.store %></div><% } %>
      </div>
      <div style="text-align:right;">
        <div class="text-muted" style="font-size:13px;">狀態</div>
        <span class="status status-<%= order.status %>" style="font-size:14px;padding:4px 14px;">
          <%= statusLabel(order.status) %>
        </span>
      </div>
    </div>
    <div class="text-muted" style="font-size:13px;margin-top:8px;">
      下單時間：<%= new Date(order.created_at).toLocaleString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false, timeZone: 'Asia/Taipei' }) %>
    </div>
    <% if (order.notes) { %>
      <div style="margin-top:8px;padding:10px;background:#f8fafc;border-radius:6px;font-size:13px;">
        <strong>備註：</strong><%= order.notes %>
      </div>
    <% } %>
  </div>

<% var sum = 0; items.forEach(function(item) { sum += item.unit_price * item.quantity; }); %>
  <!-- Bank transfer info for unpaid transfer orders -->
  <% if (order.payment_method === 'transfer' && order.payment_status === 'pending') { %>
  <div class="card" style="border:2px solid #fde68a;background:#fffbeb;">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:12px;color:#92400e;">&#x1F4B0; 彙款資訊</h2>
    <div style="font-size:14px;line-height:2;">
      <div><strong>銀行代碼：</strong>台新銀行(812)</div>
      <div><strong>帳號：</strong>2106-10-0033168-5</div>
      <div><strong>金額：</strong><span style="color:var(--danger);font-weight:700;">$<%= Number(sum - order.points_used).toLocaleString() %></span></div>
    </div>
    <form action="/orders/<%= order.id %>/pay" method="POST" style="margin-top:12px;padding-top:12px;border-top:1px solid #fde68a;">
      <div class="form-group" style="margin-bottom:8px;">
        <label for="payment_last5" style="font-size:13px;font-weight:600;color:#92400e;">彙款帳號後五碼 *</label>
        <input type="text" id="payment_last5" name="payment_last5" placeholder="請輸入後5 位數字" maxlength="5" pattern="[0-9]{5}" required style="width:160px;padding:8px 10px;border:1px solid #fde68a;border-radius:6px;font-size:14px;background:#fff;" oninput="document.getElementById('payBtn').disabled = this.value.length !== 5 || !/^\d{5}$/.test(this.value)">
      </div>
      <button type="submit" id="payBtn" class="btn btn-success" disabled style="font-size:14px;">&#x2705; 確認彙款</button>
    </form>
    <div style="margin-top:12px;padding-top:8px;border-top:1px solid #fde68a;text-align:center;">
      <a href="#" onclick="document.getElementById('changePayMethod').style.display='block';this.style.display='none';return false;" style="font-size:13px;color:#92400e;">更換付款方式</a>
      <div id="changePayMethod" style="display:none;margin-top:8px;">
        <form action="/orders/<%= order.id %>/change-payment" method="POST">
          <label style="display:inline-flex;align-items:center;gap:4px;font-size:13px;cursor:pointer;margin-right:12px;"><input type="radio" name="payment_method" value="salary" required> 扣薪</label>
          <label style="display:inline-flex;align-items:center;gap:4px;font-size:13px;cursor:pointer;"><input type="radio" name="payment_method" value="hq_pickup" required> 總部取付</label>
          <button type="submit" class="btn btn-outline btn-sm" style="margin-left:8px;font-size:12px;">確認變更</button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

  <!-- Points summary -->
  <% if (order.points_used > 0 || order.points_earned > 0) { %>
  <div class="card" style="background:#fefce8;border:1px solid #fde68a;">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:8px;">&#x1F4B3; 積點明細</h2>
    <div style="font-size:14px;">
      <% if (order.points_used > 0) { %>
      <div class="flex-between" style="margin-bottom:4px;">
        <span>使用積點抵扣</span>
        <span style="color:var(--success);font-weight:600;">- <%= Number(order.points_used).toLocaleString() %> 點</span>
      </div>
      <% } %>
      <% if (order.points_earned > 0) { %>
      <div class="flex-between">
        <span>購物獲得積點</span>
        <span style="color:var(--primary);font-weight:600;">+ <%= Number(order.points_earned).toLocaleString() %> 點</span>
      </div>
      <% } %>
    </div>
  </div>
  <% } %>

  <div class="card">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:12px;">訂單明細</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>商品</th>
            <th>規格/顏色</th>
            <th>缺陷原因</th>
            <th>單價</th>
            <th>數量</th>
            <th>小計</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach(function(item) { %>
          <% var subtotal = item.unit_price * item.quantity; %>
          <tr>
            <td style="display:flex;align-items:center;gap:8px;"><% if (item.image_url) { %><img src="<%= item.image_url %>" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:4px;border:1px solid var(--border);"><% } %><strong><%= item.name %></strong></td>
            <td class="text-muted" style="font-size:13px;"><% var sz = item.product_size; var cl = item.product_color; %><%= (sz ? sz : '') %><%= (sz && cl ? ' / ' : '') %><%= (cl ? cl : '') %><%= (!sz && !cl ? '-' : '') %></td>
            <td class="text-muted"><%= item.defect_reason || '-' %></td>
            <td>$<%= Number(item.unit_price).toLocaleString() %></td>
            <td><%= item.quantity %></td>
            <td style="font-weight:600;">$<%= Number(subtotal).toLocaleString() %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- Order total summary -->
    <div style="margin-top:12px;padding-top:12px;border-top:2px solid var(--border);">
      <div class="flex-between" style="font-size:14px;">
        <span>商品總計</span>
        <span>$<%= Number(sum).toLocaleString() %></span>
      </div>
      <% if (order.points_used > 0) { %>
      <div class="flex-between" style="font-size:14px;color:var(--success);">
        <span>積點抵扣</span>
        <span>- <%= Number(order.points_used).toLocaleString() %> 點（$<%= Number(order.points_used).toLocaleString() %>）</span>
      </div>
      <% } %>
      <div class="flex-between" style="font-size:18px;font-weight:700;margin-top:4px;">
        <span>實付金額</span>
        <span style="color:var(--danger);">$<%= Number(sum - order.points_used).toLocaleString() %></span>
      </div>
    </div>
  </div>
</div>
