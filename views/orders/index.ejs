<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F4CB; <%= typeof myOrders !== 'undefined' && myOrders ? '我的訂單' : '所有訂單' %></h1>
    <% if (typeof myOrders !== 'undefined' && myOrders) { %>
      <a href="/orders/export" class="btn btn-primary btn-sm">&#x1F4E5; 匯出 Excel</a>
      <a href="/orders" class="btn btn-outline">查看所有訂單</a>
    <% } else { %>
      <a href="/orders/export" class="btn btn-primary btn-sm">📥 匯出 Excel</a>
      <a href="/orders/my" class="btn btn-outline">我的訂單</a>
    <% } %>
  </div>

    <% if (currentUser && currentUser.role === "admin" && (!myOrders)) { %>
  <form id="batchForm" action="/orders/batch-status" method="POST" class="flex-between mb-4" style="padding:12px 16px;background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);border:1px solid var(--border);">
    <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
      <span style="font-size:13px;font-weight:600;color:var(--text-secondary);">批次操作：</span>
      <button type="submit" name="action" value="accept" class="btn btn-primary btn-sm" onclick="return confirmBatch('確認')">&#x2705; 批次確認</button>
      <button type="submit" name="action" value="ship" class="btn btn-primary btn-sm" onclick="return confirmBatch('出貨')">&#x1F69A; 批次出貨</button>
      <button type="submit" name="action" value="complete" class="btn btn-primary btn-sm" onclick="return confirmBatch('完成')">&#x1F3C1; 批次完成</button>
      <input type="hidden" id="batchIds" name="ids" value="">
    </div>
  </form>
  <script>
  function confirmBatch(label) {
    var ids = [];
    document.querySelectorAll('.order-check:checked').forEach(function(cb) { ids.push(cb.value); });
    if (ids.length === 0) { alert('請先勾選訂單'); return false; }
    document.getElementById('batchIds').value = JSON.stringify(ids);
    return confirm('確定要批次' + label + ' ' + ids.length + ' 筆訂單？');
  }
  function toggleAll(src) {
    document.querySelectorAll('.order-check').forEach(function(cb) { cb.checked = src.checked; });
  }
  </script>
  <% } %>

  <% if (orders.length === 0) { %>
    <div class="empty-state">
      <div class="icon">&#x1F4CB;</div>
      <p>目前還沒有訂單記錄</p>
      <a href="/products" class="btn btn-primary mt-4">去購物</a>
    </div>
  <% } else { %>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="width:30px;"><% if (currentUser && currentUser.role === "admin" && (!myOrders)) { %><input type="checkbox" onchange="toggleAll(this)"><% } %></th>
              <th>訂單編號</th>
              <th>下單員工</th>
              <th>品項</th>
              <th>隸屬門市</th>
              <th>總金額</th>
              <th>狀態</th>
              <th>下單時間</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(function(o) { %>
            <tr>
              <td><% if (currentUser && currentUser.role === "admin" && (!myOrders)) { %><input type="checkbox" class="order-check" value="<%= o.id %>"><% } %></td>
              <td><strong>#<%= o.id %></strong></td>
              <td><%= o.display_name %></td>
              <td><%= o.items_count %> 件</td>
              <td><%= o.store || '-' %></td>
              <td style="font-weight:600;">$<%= Number(o.total_amount || 0).toLocaleString() %></td>
              <td><span class="status status-<%= o.status %>"><%= statusLabel(o.status) %></span></td>
              <td class="text-muted"><%= new Date(o.created_at).toLocaleString('zh-TW') %></td>
              <td><a href="/orders/<%= o.id %>" class="btn btn-outline btn-sm">詳細</a></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>
</div>
