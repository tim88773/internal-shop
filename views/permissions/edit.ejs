<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F512; 編輯權限：<%= employee.display_name %></h1>
    <a href="/permissions" class="btn btn-outline">&larr; 返回權限列表</a>
  </div>

  <div class="card">
    <div style="margin-bottom:16px;padding:12px 16px;background:#f8fafc;border-radius:8px;font-size:14px;">
      <strong>員工：</strong><%= employee.display_name %>
      <span style="margin-left:16px;"><strong>帳號：</strong><%= employee.username %></span>
      <span style="margin-left:16px;"><strong>門市：</strong><%= employee.store || '-' %></span>
    </div>

    <form action="/permissions/<%= employee.id %>/edit" method="POST">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th style="min-width:100px;">模組</th>
              <% actions.forEach(function(act) { %>
                <th style="text-align:center;"><%= act.label %></th>
              <% }); %>
            </tr>
          </thead>
          <tbody>
            <% modules.forEach(function(mod) { %>
            <tr>
              <td><strong><%= mod.label %></strong></td>
              <% actions.forEach(function(act) { %>
              <td style="text-align:center;">
                <% var checked = (currentPerms[mod.id] && currentPerms[mod.id][act.id]) ? 'checked' : ''; %>
                <input type="checkbox" name="perm_<%= mod.id %>_<%= act.id %>" value="1" <%= checked %> style="width:18px;height:18px;cursor:pointer;">
              </td>
              <% }); %>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <div style="margin-top:16px;display:flex;gap:12px;align-items:center;">
        <button type="submit" class="btn btn-primary">&#x1F4BE; 儲存權限設定</button>
        <a href="/permissions" class="btn btn-outline">取消</a>
      </div>
    </form>
  </div>
</div>
