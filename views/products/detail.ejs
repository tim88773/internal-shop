<div class="container">
  <div class="mb-4">
    <a href="/products" class="btn btn-outline">&larr; 回商品列表</a>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
    <% if (images.length > 0) { %>
    <!-- Left: Image gallery -->
    <div>
      <div id="mainImage" style="background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);overflow:hidden;margin-bottom:12px;">
        <img src="<%= images[0].image_url %>" onerror="this.style.display='none'" alt="<%= product.name %>" style="width:100%;height:400px;object-fit:cover;display:block;">
      </div>
      <% if (images.length > 1) { %>
      <div style="display:flex;gap:8px;overflow-x:auto;padding-bottom:4px;">
        <% images.forEach(function(img, idx) { %>
          <img src="<%= img.image_url %>" onerror="this.style.display='none'" alt="" style="width:72px;height:72px;object-fit:cover;border-radius:6px;border:2px solid <%= idx === 0 ? 'var(--primary)' : 'var(--border)' %>;cursor:pointer;flex-shrink:0;" onclick="document.querySelector('#mainImage img').src=this.src;document.querySelectorAll('#mainImage ~ div img').forEach(function(i){i.style.borderColor='var(--border)'});this.style.borderColor='var(--primary)';">
        <% }); %>
      </div>
      <% } %>
    </div>
    <% } else { %>
    <!-- No image placeholder -->
    <div style="background:var(--surface);border-radius:var(--radius);box-shadow:var(--shadow);display:flex;align-items:center;justify-content:center;min-height:300px;">
      <span class="text-muted" style="font-size:48px;">&#x1F5BC;</span>
    </div>
    <% } %>

    <!-- Right: Product info -->
    <div>
      <div class="card">
        <div style="margin-bottom:4px;">
          <% if (product.category_name) { %><span style="font-size:12px;color:var(--primary);background:#eff6ff;padding:2px 10px;border-radius:4px;"><%= product.category_name %></span><% } %>
        </div>
        <h1 style="font-size:24px;font-weight:700;margin-bottom:8px;"><%= product.name %></h1>

        <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:12px;">
          <span style="font-size:32px;font-weight:700;color:var(--danger);">$<%= Number(product.price).toLocaleString() %></span>
          <% if (product.original_price) { %>
            <span style="font-size:16px;color:var(--text-secondary);text-decoration:line-through;">$<%= Number(product.original_price).toLocaleString() %></span>
            <span style="font-size:13px;color:var(--success);font-weight:600;">-<%= Math.round((1 - product.price/product.original_price)*100) %>%</span>
          <% } %>
        </div>

        <% if (product.defect_reason) { %>
        <div style="background:#fef3c7;border:1px solid #fde68a;border-radius:8px;padding:12px;margin-bottom:16px;">
          <div style="font-weight:600;font-size:13px;color:#92400e;margin-bottom:4px;">&#x26A0; 瑕疵說明</div>
          <div style="font-size:14px;color:#78350f;"><%= product.defect_reason %></div>
        </div>
        <% } %>

        <% if (product.description) { %>
        <div style="margin-bottom:16px;">
          <div style="font-weight:600;font-size:13px;color:var(--text-secondary);margin-bottom:4px;">商品描述</div>
          <div style="font-size:14px;line-height:1.7;white-space:pre-wrap;"><%= product.description %></div>
        </div>
        <% } %>

        <div style="margin-bottom:16px;">
          <div style="font-weight:600;font-size:13px;color:var(--text-secondary);margin-bottom:4px;">庫存</div>
          <div style="font-size:14px;">
            <span style="color:<%= product.quantity <= 3 ? 'var(--danger)' : 'var(--success)' %>;font-weight:600;">
              &#x1F4E6; <%= product.quantity %> 件
            </span>
            <% if (product.quantity === 0) { %>
              <span style="color:var(--danger);font-weight:600;margin-left:8px;">（已售罄）</span>
            <% } %>
          </div>
        </div>

        <% if (product.is_active && product.quantity > 0) { %>
        <form action="/orders/cart/add" method="POST">
          <input type="hidden" name="product_id" value="<%= product.id %>">
          <div style="display:flex;gap:12px;margin-bottom:12px;">
            <% if (productSizes.length > 0) { %>
            <div>
              <label for="size" style="font-size:13px;color:var(--text-secondary);display:block;margin-bottom:4px;">尺寸</label>
              <select id="size" name="size" style="padding:10px 12px;border:1px solid var(--border);border-radius:6px;font-size:14px;">
                <option value="">請選擇</option>
                <% productSizes.forEach(function(s) { %>
                <option value="<%= s %>"><%= s %></option>
                <% }); %>
              </select>
            </div>
            <% } %>
            <% if (productColors.length > 0) { %>
            <div>
              <label for="color" style="font-size:13px;color:var(--text-secondary);display:block;margin-bottom:4px;">顏色</label>
              <select id="color" name="color" style="padding:10px 12px;border:1px solid var(--border);border-radius:6px;font-size:14px;">
                <option value="">請選擇</option>
                <% productColors.forEach(function(c) { %>
                <option value="<%= c %>"><%= c %></option>
                <% }); %>
              </select>
            </div>
            <% } %>
          </div>
          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;padding-top:16px;border-top:1px solid var(--border);">
            <div style="display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap;">
              <div>
                <label for="qty" style="font-size:13px;color:var(--text-secondary);display:block;margin-bottom:4px;">數量</label>
                <input type="number" id="qty" name="quantity" value="1" min="1" max="<%= product.quantity %>" style="width:70px;padding:10px 12px;border:1px solid var(--border);border-radius:6px;font-size:14px;">
              </div>
              <button type="submit" class="btn btn-primary" style="padding:12px 28px;font-size:15px;">&#x1F6D2; 加入購物車</button>
            </div>
          </div>
        </form>
        <% if (inCart > 0) { %>
          <div style="margin-top:8px;font-size:13px;color:var(--success);">已在購物車中的數量：<%= inCart %></div>
        <% } %>
        <% } else { %>
          <div style="padding:16px;text-align:center;border-top:1px solid var(--border);color:var(--text-secondary);">
            <%= product.is_active ? '暫時缺貨' : '該商品已下架' %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (related.length > 0) { %>
  <div class="card" style="margin-top:24px;">
    <h2 style="font-size:16px;font-weight:600;margin-bottom:16px;">推薦商品</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;">
      <% related.forEach(function(r) { %>
      <a href="/products/<%= r.id %>" style="text-decoration:none;color:inherit;">
        <div style="background:var(--surface);border-radius:8px;box-shadow:var(--shadow);overflow:hidden;transition:transform 0.15s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform=''">
          <% if (r.image_url) { %>
          <div style="height:120px;overflow:hidden;">
            <img src="<%= r.image_url %>" onerror="this.style.display='none'" alt="<%= r.name %>" style="width:100%;height:100%;object-fit:cover;">
          </div>
          <% } %>
          <div style="padding:10px;">
            <div style="font-size:13px;font-weight:600;margin-bottom:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= r.name %></div>
            <div style="font-size:16px;font-weight:700;color:var(--danger);">$<%= Number(r.price).toLocaleString() %></div>
          </div>
        </div>
      </a>
      <% }); %>
    </div>
  </div>
  <% } %>
</div>
