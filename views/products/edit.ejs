<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x270F; 編輯商品</h1>
    <a href="/products/manage" class="btn btn-outline">回到管理</a>
  </div>

  <div class="card">
    <form action="/products/<%= product.id %>/edit" method="POST" enctype="multipart/form-data">
      <div class="form-row">
        <div class="form-group">
          <label for="name">商品名稱 *</label>
          <input type="text" id="name" name="name" value="<%= product.name %>" required>
        </div>
        <div class="form-group">
          <label for="category_id">分類</label>
          <select id="category_id" name="category_id">
            <option value="">無分類</option>
            <% categories.forEach(function(c) { %>
              <option value="<%= c.id %>" <%= product.category_id == c.id ? 'selected' : '' %>><%= c.name %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="form-group">
        <label for="description">商品描述</label>
        <textarea id="description" name="description"><%= product.description || '' %></textarea>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="price">售價 *</label>
          <input type="number" id="price" name="price" step="1" min="0" value="<%= product.price %>" required>
        </div>
        <div class="form-group">
          <label for="original_price">原價</label>
          <input type="number" id="original_price" name="original_price" step="1" min="0" value="<%= product.original_price || '' %>">
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="quantity">庫存數量</label>
          <input type="number" id="quantity" name="quantity" min="0" value="<%= product.quantity %>">
        </div>
        <div class="form-group">
          <label for="defect_reason">瑕疵說明</label>
          <input type="text" id="defect_reason" name="defect_reason" value="<%= product.defect_reason || '' %>">
        </div>
      </div>

      <div class="form-group">
        <label for="image">????</label>
        <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/gif,image/webp">
        <div class="text-muted" style="font-size:12px;margin-top:4px;">?? JPG?PNG?GIF?WebP??? 5MB</div>
        <% if (product.image_url) { %>
          <div style="margin-top:8px;display:flex;align-items:center;gap:12px;">
            <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width:80px;height:80px;object-fit:cover;border-radius:6px;border:1px solid var(--border);">
            <span class="text-muted" style="font-size:12px;">??????????????</span>
          </div>
        <% } %>
      </div>

      <div class="form-check mb-4">
        <input type="checkbox" id="is_active" name="is_active" value="1" <%= product.is_active ? 'checked' : '' %>>
        <label for="is_active" style="margin:0;">上架中（取消勾選即下架）</label>
      </div>

      <div class="form-group">
        <button type="submit" class="btn btn-primary">&#x1F504; 儲存變更</button>
        <a href="/products/manage" class="btn btn-outline">取消</a>
      </div>
    </form>
  </div>
</div>
