<% var searchVal = typeof search !== 'undefined' ? search : ''; %>
<% var catId = typeof categoryId !== 'undefined' ? categoryId : ''; %>
<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F50D; 商品瀏覽</h1>
    <span class="text-muted">僅顯示上架中商品</span>
  </div>

  <form class="search-bar" method="GET">
    <input type="text" name="search" placeholder="搜尋商品名稱或描述..." value="<%= searchVal %>">
    <select name="category">
      <option value="">所有分類</option>
      <% categories.forEach(function(c) { %>
        <option value="<%= c.id %>" <%= String(catId) === String(c.id) ? 'selected' : '' %>><%= c.name %></option>
      <% }); %>
    </select>
    <button type="submit" class="btn btn-primary">搜尋</button>
    <% if (searchVal || catId) { %>
      <a href="/products" class="btn btn-outline">清除</a>
    <% } %>
  </form>

  <% if (products.length === 0) { %>
    <div class="empty-state">
      <div class="icon">&#x1F50D;</div>
      <p><%= (searchVal || catId) ? '沒有符合條件的商品' : '目前還沒有任何商品上架' %></p>
      <% if (!(searchVal || catId)) { %>
        <p class="text-muted">等待管理員上架商品中...</p>
      <% } else { %>
        <a href="/products" class="btn btn-outline mt-4">顯示全部商品</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="product-grid">
      <% products.forEach(function(p) { %>
      <div class="product-card">
        <div class="body">
          <% if (p.image_url) { %>
            <div style="margin:-16px -16px 12px -16px;height:160px;overflow:hidden;border-radius:10px 10px 0 0;">
              <a href="/products/<%= p.id %>"><img src="<%= p.image_url %>" onerror="this.style.display='none'" alt="<%= p.name %>" style="width:100%;height:100%;object-fit:cover;"></a>
            </div>
          <% } %>
          <a href="/products/<%= p.id %>" style="text-decoration:none;color:inherit;"><div class="name"><%= p.name %></div></a>
          <% if (p.category_name) { %><span style="font-size:11px;color:var(--text-secondary);"><%= p.category_name %></span><% } %>
          <% if (p.store) { %><span style="font-size:11px;color:var(--primary);margin-left:6px;">📍 <%= p.store %></span><% } %>
          <div class="desc"><%= p.description || '無描述' %></div>

          <div class="price-row">
            <span class="price">$<%= Number(p.price).toLocaleString() %></span>
            <% if (p.original_price) { %>
              <span class="original-price">$<%= Number(p.original_price).toLocaleString() %></span>
            <% } %>
          </div>

          <% if (p.defect_reason) { %>
            <div class="defect-tag">&#x26A0; 瑕疵：<%= p.defect_reason %></div>
          <% } %>

          <div class="stock <%= p.quantity <= 3 ? 'low' : '' %>">
            &#x1F4E6; 庫存：<%= p.quantity %> 件
            <% if (p.quantity === 0) { %><span style="color:var(--danger);font-weight:600;">（已售罄）</span><% } %>
          </div>

          <% var pSizes = []; var pColors = []; try { pSizes = JSON.parse(p.sizes || "[]"); } catch(e){} try { pColors = JSON.parse(p.colors || "[]"); } catch(e){} %>
          <form action="/orders/cart/add" method="POST" style="margin-top:10px;" onsubmit="return validateCart(this)">
            <input type="hidden" name="product_id" value="<%= p.id %>">
            <div style="display:flex;gap:6px;margin-bottom:6px;flex-wrap:wrap;">
              <% if (pSizes.length > 0) { %>
              <select name="size" required style="flex:1;min-width:55px;padding:6px 8px;border:1px solid var(--border);border-radius:4px;font-size:13px;background:#fff;">
                <option value="">尺寸</option>
                <% pSizes.forEach(function(s) { %>
                <option value="<%= s %>"><%= s %></option>
                <% }); %>
              </select>
              <% } %>
              <% if (pColors.length > 0) { %>
              <select name="color" required style="flex:1;min-width:55px;padding:6px 8px;border:1px solid var(--border);border-radius:4px;font-size:13px;background:#fff;">
                <option value="">顏色</option>
                <% pColors.forEach(function(c) { %>
                <option value="<%= c %>"><%= c %></option>
                <% }); %>
              </select>
              <% } %>
              <input type="number" name="quantity" value="1" min="1" max="<%= p.quantity %>" style="width:50px;padding:6px 8px;border:1px solid var(--border);border-radius:4px;font-size:13px;">
              <button type="submit" class="btn btn-primary btn-sm" <%= p.quantity === 0 ? 'disabled style="opacity:0.5;cursor:not-allowed;"' : '' %>><%= p.quantity === 0 ? '已售罄' : '加入' %></button>
            </div>
          </form>        </div>
      </div>
      <% }); %>
    </div>
  <% } %>
</div>

<script>
function validateCart(form) {
  var selects = form.querySelectorAll('select[required]');
  for (var i = 0; i < selects.length; i++) {
    if (!selects[i].value) {
      alert('請選擇 ' + (selects[i].name === 'size' ? '尺寸' : '顏色'));
      selects[i].focus();
      return false;
    }
  }
  return true;
}
</script>
