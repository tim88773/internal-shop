<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x2699; 商品管理</h1>
    <div class="btn-group">
            <button id="batchDeleteBtn" class="btn btn-danger btn-sm" onclick="batchDelete()" style="display:none;">✂ 批次刪除</button>
    </div>
  </div>

  <div class="card">
    <div class="table-wrap">
      <table>
        <thead>
                    <tr>
            <th style="width:30px;"><input type="checkbox" id="selectAll" onclick="toggleAll(this)"></th>
            <th>ID</th>
            <th>封面</th>
            <th>名稱</th>
            <th>款式號碼</th>
            <th>分類</th>
            <th>所屬門市</th>
            <th>售價</th>
            <th>原價</th>
            <th>庫存</th>
            <th>狀態</th>
            <th>建立時間</th>
            <th>操作</th>
          </tr>        </thead>
        <tbody>
          <% products.forEach(function(p) { %>
          <tr>
            <td><input type="checkbox" class="product-check" value="<%= p.id %>"></td>
            <td>#<%= p.id %></td>
            <td>
              <% if (p.image_url) { %>
                <img src="<%= p.image_url %>" alt="<%= p.name %>" style="width:40px;height:40px;object-fit:cover;border-radius:4px;border:1px solid var(--border);">
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
            <td><strong><%= p.name %></strong></td>
            <td><%= p.style_code || '-' %></td>
            <td><%= p.category_name || '-' %></td>
            <td><%= p.store || '-' %></td>
            <td style="color:var(--danger);font-weight:600;">$<%= Number(p.price).toLocaleString() %></td>
            <td class="text-muted"><%= p.original_price ? '$' + Number(p.original_price).toLocaleString() : '-' %></td>
            <td><%= p.quantity %></td>
            <td>
              <span class="status <%= p.is_active ? 'status-pending' : 'status-cancelled' %>">
                <%= p.is_active ? '上架' : '下架' %>
              </span>
            </td>
            <td class="text-muted"><%= new Date(p.created_at).toLocaleString('zh-TW', { year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false, timeZone: 'Asia/Taipei' }) %></td>
            <td>
              <div class="actions">
                <a href="/products/<%= p.id %>/edit" class="btn btn-outline btn-sm">編輯</a>
                <form action="/products/<%= p.id %>/toggle" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm <%= p.is_active ? 'btn-warning' : 'btn-success' %>">
                    <%= p.is_active ? '下架' : '上架' %>
                  </button>
                </form>
                <form action="/products/<%= p.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('確定刪除此商品？')">
                  <button type="submit" class="btn btn-sm btn-danger" style="padding:6px 10px;font-size:12px;">&#x1F5D1;</button>
                </form>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
function toggleAll(source) {
  var checkboxes = document.querySelectorAll('.product-check');
  var btn = document.getElementById('batchDeleteBtn');
  for (var i = 0; i < checkboxes.length; i++) {
    checkboxes[i].checked = source.checked;
  }
  btn.style.display = source.checked ? 'inline-flex' : 'none';
}

function batchDelete() {
  var checked = document.querySelectorAll('.product-check:checked');
  if (checked.length === 0) {
    alert('請選擇至少一個商品');
    return;
  }
  if (!confirm('確定要刪除所選的 ' + checked.length + ' 個商品？此操作不可撤回！')) {
    return;
  }
  var ids = [];
  for (var i = 0; i < checked.length; i++) {
    ids.push(checked[i].value);
  }
  var form = document.createElement('form');
  form.method = 'POST';
  form.action = '/products/batch-delete';
  var input = document.createElement('input');
  input.type = 'hidden';
  input.name = 'ids';
  input.value = JSON.stringify(ids);
  form.appendChild(input);
  document.body.appendChild(form);
  form.submit();
}

// Show batch delete button when any checkbox is checked
document.addEventListener('change', function(e) {
  if (e.target.classList.contains('product-check')) {
    var checked = document.querySelectorAll('.product-check:checked');
    document.getElementById('batchDeleteBtn').style.display = checked.length > 0 ? 'inline-flex' : 'none';
  }
});
</script>
