<div class="container">
  <div class="flex-between mb-4">
    <h1 style="font-size:22px;font-weight:700;">&#x1F4C3; 積點異動歷程</h1>
    <a href="/profile" class="btn btn-outline">返回會員資料</a>
  </div>

  <div class="card" style="max-width:600px;margin:0 auto;">
    <div class="flex-between mb-2">
      <div>
        <span style="font-size:14px;font-weight:600;"><%= user.display_name %></span>
        <span class="text-muted" style="margin-left:8px;font-size:13px;">目前積點：<strong style="color:var(--warning);"><%= Number(user.points || 0).toLocaleString() %></strong> 點</span>
      </div>
    </div>

    <% if (transactions.length === 0) { %>
      <div class="empty-state">
        <p>尚無積點異動紀錄</p>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>日期</th>
              <th>類型</th>
              <th>異動點數</th>
              <th>餘額</th>
              <th>說明</th>
            </tr>
          </thead>
          <tbody>
            <% transactions.forEach(function(t) { %>
            <tr>
              <td class="text-muted"><%= new Date(t.created_at).toLocaleString('zh-TW', { month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', hour12:false, timeZone:'Asia/Taipei' }) %></td>
              <td>
                <% if (t.type === 'earn') { %>
                  <span style="color:var(--primary);font-weight:600;">獲得</span>
                <% } else if (t.type === 'spend') { %>
                  <span style="color:var(--success);font-weight:600;">使用</span>
                <% } else if (t.type === 'admin_add') { %>
                  <span style="color:var(--primary);font-weight:600;">管理員給點</span>
                <% } else if (t.type === 'admin_deduct') { %>
                  <span style="color:var(--danger);font-weight:600;">管理員扣點</span>
                <% } else { %>
                  <span><%= t.type %></span>
                <% } %>
              </td>
              <td style="font-weight:600;">
                <% if (t.points > 0) { %>
                  <span style="color:var(--primary);">+<%= Number(t.points).toLocaleString() %></span>
                <% } else { %>
                  <span style="color:var(--danger);"><%= Number(t.points).toLocaleString() %></span>
                <% } %>
              </td>
              <td><%= Number(t.balance_after).toLocaleString() %></td>
              <td class="text-muted" style="font-size:13px;">
                <%= t.note || '' %>
                <% if (t.reference_type === 'order') { %>
                  <a href="/orders/<%= t.reference_id %>">(訂單 #<%= t.reference_id %>)</a>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
